# Firebase web config — copy this file to ".env" and fill with your real values.
# Get these from: Firebase Console → Project settings (gear icon) → General
# → scroll to "Your apps" → Web app → "SDK setup and configuration" → Config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth Web client ID (for Google One Tap sign-in). From Google Cloud
# Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web). Optional —
# the app falls back to the built-in ID if unset.
VITE_GOOGLE_CLIENT_ID=
