rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Registrations — any signed-in user can create/read/update/delete.
    // (Admin gating is enforced in the app UI. Tighten with custom claims
    //  later for backend-level enforcement.)
    // Anyone can submit a seller registration (no login required); only signed-in
    // admins can read/update/delete (records hold phone/email — not public).
    match /registrations/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Categories, sub-categories, stalls — readable by anyone;
    // writable by any signed-in user (admin-gated in the app UI).
    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /subcategories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stalls/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Announcements — readable by anyone, writable by signed-in admins.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Site settings (e.g. home hero image) — readable by anyone, writable by signed-in admins.
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Events & Seasons — readable by anyone, writable by signed-in admins.
    match /events/{docId}   { allow read: if true; allow write: if request.auth != null; }
    match /seasons/{docId}  { allow read: if true; allow write: if request.auth != null; }
    // Draw results — readable by anyone, writable by signed-in admins.
    match /drawResults/{docId} { allow read: if true; allow write: if request.auth != null; }
    // Draw pool — name-only applicant list (no contact info) for the public live
    // map. Readable by anyone, published by signed-in admins from the draw screen.
    match /drawPools/{docId} { allow read: if true; allow write: if request.auth != null; }
    // Payments — signed-in only (financial data; not public).
    match /payments/{docId} { allow read, write: if request.auth != null; }

    // User profiles — each user can read/write only their own (uid == doc id).
    match /users/{uid} { allow read, write: if request.auth != null && request.auth.uid == uid; }

    // Everything else locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
