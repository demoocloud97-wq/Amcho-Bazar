rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Admin allowlist (must match src/lib/admin-config.ts) ----
    // Only these signed-in emails may write admin-managed data. Any other
    // logged-in user (incl. Google sign-in) is treated as a normal visitor.
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        "alfajaryouthwing@gmail.com",
        "demoocloud97@gmail.com",
        "admin@amchobazar.com"
      ];
    }

    // Live-broadcast gate: the public may read the draw only while the admin has
    // "Go Live" turned ON (settings/site.drawLiveEnabled).
    function drawIsLive() {
      return exists(/databases/$(database)/documents/settings/site)
        && get(/databases/$(database)/documents/settings/site).data.drawLiveEnabled == true;
    }

    // Registrations — anyone can submit; any signed-in user can read (needed for the
    // notification bell / "my registration"); only admins can edit or delete.
    match /registrations/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Public content — readable by anyone; writable by admins only.
    match /categories/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /subcategories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /stalls/{docId}        { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{docId}       { allow read: if true; allow write: if isAdmin(); }
    match /announcements/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId}      { allow read: if true; allow write: if isAdmin(); }
    match /events/{docId}        { allow read: if true; allow write: if isAdmin(); }
    match /seasons/{docId}       { allow read: if true; allow write: if isAdmin(); }

    // Draw results & pool — public read only while live; written by admins only.
    match /drawResults/{docId} { allow read: if request.auth != null || drawIsLive(); allow write: if isAdmin(); }
    match /drawPools/{docId}   { allow read: if request.auth != null || drawIsLive(); allow write: if isAdmin(); }

    // Payments — admins only (financial data; not public).
    match /payments/{docId} { allow read, write: if isAdmin(); }

    // User profiles — each user can read/write only their own (uid == doc id).
    match /users/{uid} { allow read, write: if request.auth != null && request.auth.uid == uid; }

    // Everything else locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
